##############################################
# Environment variables template for Production
##############################################

# =====================
# Database Configuration
# =====================
DB_USER=audioplayer
DB_PASSWORD=change_this_to_a_secure_password
DB_NAME=audioplayer

# =====================
# JWT Authentication
# =====================
JWT_SECRET_KEY=change_this_to_a_very_secure_random_string_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================
# Storage Configuration
# =====================
# Choose storage type: 'webdav' or 'local'
STORAGE_TYPE=local

# For WebDAV storage
WEBDAV_URL=http://nas.local:5005
WEBDAV_USERNAME=admin
WEBDAV_PASSWORD=change_this_password

# For local storage (NAS mount path)
LOCAL_MOUNT_PATH=/mnt/nas/audiobooks
NAS_MOUNT_PATH=/mnt/nas

# =====================
# Application Settings
# =====================
DEBUG=false
LOG_LEVEL=INFO
APP_ENV=production

# =====================
# Server Configuration
# =====================
SERVER_NAME=your-domain.com
HTTP_PORT=80
HTTPS_PORT=443

# =====================
# SSL/TLS Configuration
# =====================
# Uncomment and set these for SSL
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
# Or for Let's Encrypt:
# SSL_CERT_PATH=/etc/letsencrypt/live/${SERVER_NAME}/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/${SERVER_NAME}/privkey.pem

# =====================
# Security
# =====================
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# =====================
# Performance (Optional)
# =====================
# Redis cache URL (if using Redis)
# REDIS_URL=redis://localhost:6379/0

# =====================
# Backup Configuration
# =====================
BACKUP_DIR=/path/to/backups
BACKUP_RETENTION_DAYS=7

# =====================
# Email Configuration (Optional)
# =====================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=change_this
# SMTP_FROM=noreply@example.com
